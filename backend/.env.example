# # Copy this file to .env and fill in real values before running the server.

# PORT=5000

# # MongoDB connection string. For local dev: mongodb://127.0.0.1:27017/verme
# # For hosted: use a MongoDB Atlas connection string.
# MONGO_URI= mongodb+srv://db_user:<db_password>@cluster0.abah2vq.mongodb.net/?appName=Cluster0

# # Comma-separated list of origins allowed to call this API.
# # In dev this is your Vite dev server; in production, your deployed frontend URL.
# CORS_ORIGIN=http://localhost:5173
# #
# # ---- Phase 8 — Admin authentication (required for the admin dashboard) ----
# # 1. Choose a JWT secret — any long random string, e.g. generate with:
# #      node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET=95fe3e72e7f9769f4f3bcda0bad4e0c2d3ee48b29577aa5479a8f2126a90830134f4a9624bd99471e46549e64f71fed9
# RAZORPAY_KEY_ID=rzp_test_TBQACDSSzBSIIw
# RAZORPAY_KEY_SECRET=d03lF7xfZWp1j22ierNgbb1X
# # 2. Set the admin login email (whatever you want to log in with).
# ADMIN_EMAIL=owner@verme.example

# # 3. Generate a password hash and paste it below — run from the backend/ folder:
# #      node scripts/generate-admin-hash.js "your-chosen-password"
# ADMIN_PASSWORD_HASH=$2b$10$CfBR797o1XfbZ3lvRSXO1.sM8Jsb8yXPW1YyW9BRew9ghlotio9gG

# # ---- Phase 9 — Payments (optional) ----
# # Without these two set, the site runs in an honest "demo payment" mode:
# # visitors see a clearly-labeled demo screen instead of a real checkout,
# # so you can test the booking → pay → receipt flow before going live.
# # Get real keys from https://dashboard.razorpay.com/app/keys (test mode
# # keys work fine for trying this out before switching to live keys).
# # RAZORPAY_KEY_ID= rzp_test_TBQACDSSzBSIIw
# # RAZORPAY_KEY_SECRET= d03lF7xfZWp1j22ierNgbb1X

# # ---- Added in a future phase — not needed yet, kept here so the file only grows once ----

# # Phase 9 (Payments) — Stripe (if you choose Stripe instead of/alongside Razorpay)
# # STRIPE_SECRET_KEY=
# # STRIPE_WEBHOOK_SECRET=

# # Phase 3/4 confirmations — email (e.g. via SMTP or a provider like Resend/SendGrid)
# # EMAIL_FROM=
# # SMTP_HOST=
# # SMTP_PORT=
# # SMTP_USER=
# # SMTP_PASS=

# # Phase 3/4 confirmations — SMS (e.g. via Twilio or an Indian provider like MSG91)
# # SMS_API_KEY=
# # SMS_SENDER_ID=


PORT=5000

MONGO_URI=mongodb://db_user:Admin%40123@ac-coqnrca-shard-00-00.1u3luht.mongodb.net:27017,ac-coqnrca-shard-00-01.1u3luht.mongodb.net:27017,ac-coqnrca-shard-00-02.1u3luht.mongodb.net:27017/?ssl=true&replicaSet=atlas-1113k9-shard-0&authSource=admin&appName=Cluster0
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=95fe3e72e7f9769f4f3bcda0bad4e0c2d3ee48b29577aa5479a8f2126a90830134f4a9624bd99471e46549e64f71fed9

ADMIN_EMAIL=admin@salonacademy.com
ADMIN_PASSWORD_HASH=$2a$10$eh5QzYZLxXXIUa/lK6oaF.749Oh8Q1LaexsqoeKLcP70Keehh3mGu

